distance_mi = 111
is_raining = True
has_bike = False
has_car = True
has_ride_share_app = False

# Check falsy distance first
if not distance_mi:
    print(False)

# Distance ≤ 1 mile
elif distance_mi <= 1:
    if not is_raining:
        print(True)
    else:
        print(False)

# Distance > 1 and ≤ 6 miles
elif distance_mi <= 6:
    if has_bike and not is_raining:
        print(True)
    else:
        print(False)

# Distance > 6 miles
else:
    if has_car or has_ride_share_app:
        print(True)
    else:
        print(False)
